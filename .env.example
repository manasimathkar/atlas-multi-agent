# Copy this to `.env` and fill in your keys. Never commit `.env`.

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Tavily web search API key — https://tavily.com
TAVILY_API_KEY=tvly-...

# Model selection (sane defaults)
ATLAS_MODEL_REASONING=claude-sonnet-4-6
ATLAS_MODEL_FAST=claude-haiku-4-5-20251001

# Budgets (defense-in-depth: hard caps on agent autonomy)
ATLAS_MAX_SUBQUESTIONS=5
ATLAS_MAX_SEARCH_CALLS=10
ATLAS_MAX_CRITIC_RETRIES=1
ATLAS_MAX_TOKENS_PER_AGENT=4000
ATLAS_REQUEST_TIMEOUT_S=120

# Logging
ATLAS_LOG_LEVEL=INFO
